# Copy this file to .env and fill in your values

# Neon PostgreSQL connection string
# Get it from: https://console.neon.tech → your project → Connection Details
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/mmn_db?sslmode=require

# Server
PORT=4000
NODE_ENV=development

# JWT — generate a strong secret:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# CORS — comma-separated list of allowed frontend origins
# e.g. for multiple: https://mmn-three.vercel.app,http://localhost:5173
CORS_ORIGIN=http://localhost:5173
